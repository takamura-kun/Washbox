{
  "build": {
    "builder": "NIXPACKS",
    "nixpacksConfig": {
      "language": "php",
      "phases": {
        "install": {
          "commands": [
            "composer install --optimize-autoloader --no-dev"
          ]
        },
        "build": {
          "commands": [
            "php artisan optimize"
          ]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "php artisan serve --host=0.0.0.0 --port=$PORT",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE"
  }
}
