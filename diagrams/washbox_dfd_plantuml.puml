@startuml WashBox_DataFlowDiagram
!define ENTITY_COLOR #E1F5FE
!define PROCESS_COLOR #FFF9C4
!define DATASTORE_COLOR #F0F4C3

skinparam linetype ortho

package "External Entities" {
  actor "Customer App" as CUST #ENTITY_COLOR
  actor "Admin Panel" as ADMIN #ENTITY_COLOR
  actor "Branch Staff" as BRANCH #ENTITY_COLOR
  actor "Driver App" as DRIVER #ENTITY_COLOR
  actor "Firebase FCM" as FCM #ENTITY_COLOR
  actor "GCash API" as GCASH #ENTITY_COLOR
  actor "Email Service" as EMAIL #ENTITY_COLOR
}

package "Core Processes" {
  component "P1: Authentication\n& Profile" as P1 #FFF9C4
  component "P2: Service &\nPromotion Mgmt" as P2 #FFF9C4
  component "P3: Pickup Request\nManagement" as P3 #FFF9C4
  component "P4: Laundry Order\nProcessing" as P4 #FFF9C4
  component "P5: Payment\nVerification" as P5 #FFF9C4
  component "P6: Inventory &\nStock Mgmt" as P6 #FFF9C4
  component "P7: Location\nTracking" as P7 #FFF9C4
  component "P8: Status &\nNotifications" as P8 #FFF9C4
  component "P9: Financial\nTracking" as P9 #FFF9C4
  component "P10: Reporting &\nAnalytics" as P10 #FFF9C4
  component "P11: Device Token\nManagement" as P11 #FFF9C4
  component "P12: Audit\nLogging" as P12 #FFF9C4
}

package "Data Stores" {
  database "D1: Customer\nAccounts\n(15,000)" as D1 #F0F4C3
  database "D2: Services &\nCategories\n(300)" as D2 #F0F4C3
  database "D3: Pickup\nRequests\n(50,000)" as D3 #F0F4C3
  database "D4: Laundry\nOrders\n(100,000)" as D4 #F0F4C3
  database "D5: Payment\nRecords\n(80,000)" as D5 #F0F4C3
  database "D6: Inventory\nItems\n(5,000)" as D6 #F0F4C3
  database "D7: Location\nHistory\n(1,000,000)" as D7 #F0F4C3
  database "D8: Promotions\n(500)" as D8 #F0F4C3
  database "D9: Device\nTokens\n(20,000)" as D9 #F0F4C3
  database "D10: Financial\nTransactions\n(200,000)" as D10 #F0F4C3
  database "D11: Audit\nLogs\n(1,000,000)" as D11 #F0F4C3
}

''' External Entity to Process Flows
CUST --> P1: login, profile data
CUST --> P3: request pickup
CUST --> P4: submit laundry items
CUST --> P5: submit payment proof

ADMIN --> P2: manage services
ADMIN --> P10: view reports
ADMIN --> P5: verify payments

BRANCH --> P3: accept/update pickup
BRANCH --> P4: process laundry
BRANCH --> P6: manage inventory

DRIVER --> P3: accept pickup
DRIVER --> P7: update location
DRIVER --> P4: deliver laundry

FCM --> P8: send notifications
FCM <-- P11: token registration

GCASH --> P5: payment validation
GCASH --> P9: payment status

EMAIL --> P8: send emails
EMAIL <-- P8: email data

''' Process to Data Store Flows
P1 --> D1: read/write customer data
P1 <-- D1: customer info

P2 --> D2: read/write services
P2 --> D8: read/write promotions

P3 --> D3: create/update pickups
P3 --> D1: read customer info
P3 <-- D3: pickup status

P4 --> D4: create/update orders
P4 --> D6: read inventory
P4 --> D3: read pickup info
P4 <-- D4: order status

P5 --> D5: store payment proof
P5 --> D4: read laundry amount
P5 --> D1: read customer info
P5 <-- D5: payment status

P6 --> D6: update stock levels
P6 --> D4: read order items
P6 <-- D6: inventory status

P7 --> D7: store location data
P7 --> D3: read pickup info
P7 <-- D7: tracking history

P8 --> D9: read device tokens
P8 --> D3: read pickup status
P8 --> D4: read order status
P8 --> D5: read payment status

P9 --> D10: record transactions
P9 --> D5: read payments
P9 --> D4: read orders

P10 --> D1: read customer data
P10 --> D3: read pickups
P10 --> D4: read laundry orders
P10 --> D5: read payments
P10 --> D10: read transactions

P11 --> D9: store/update tokens
P11 <-- D9: token info

P12 --> D11: log all actions
P12 --> D1: log user activities
P12 --> D3: log pickup changes
P12 --> D5: log payment changes

''' Inter-Process Flows
P1 -.-> P11: customer ID
P3 -.-> P4: pickup completed
P4 -.-> P5: order completed
P5 -.-> P9: payment confirmed
P3 -.-> P8: pickup status change
P4 -.-> P8: laundry status change
P5 -.-> P8: payment status change
P7 -.-> P8: location update

@enduml
